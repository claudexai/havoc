{
  "name": "havoc",
  "version": "0.1.0",
  "description": "Multi-agent API adversarial testing engine",
  "type": "module",
  "main": "dist/cli/index.js",
  "bin": {
    "havoc": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli/index.ts",
    "start": "node dist/cli/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:server": "node test-server/server.js"
  },
  "repository": {
    "type": "git",
    "url": "git@github-personal:claudexai/havoc.git"
  },
  "keywords": [
    "api",
    "testing",
    "fuzzing",
    "adversarial"
  ],
  "author": "claudexai",
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@apidevtools/swagger-parser": "^12.1.0",
    "@faker-js/faker": "^10.3.0",
    "better-sqlite3": "^12.6.2",
    "commander": "^14.0.3",
    "undici": "^7.22.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.3.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
